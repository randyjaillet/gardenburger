//////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////
//
// Options
//
//////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////

// Below this value constitutes mobile mode.
// If you change this, remember to set it in the JS as well via
// the "responsiveBreakpoint" option upon instantiation.
breakpoint = 800px

// If you change this to vertical, remember to set it in the JS
// as well via the "orientation" option upon instantiation. If
// you don't, the edge-conscious positioning of the flyouts will
// be wonky.
navOrientation = horizontal

mobileNavStyle = inline


body > header > nav


	//////////////////////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////
	//
	// Aesthetics
	//
	//////////////////////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////
		
	text-align center
	background #F5F5F5



	//////////////////////////////////////////////////////////////////
	// TOP UL ONLY	//////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////

	if mobileNavStyle is offscreen
		> ul
			background #555
			box-shadow inset -2px 0 5px -5px
			@media (min-width: breakpoint)
				background #F5F5F5



	//////////////////////////////////////////////////////////////////
	// ALL MENUS	//////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////
	// (including the top-level, always-visible one)

	ul
		margin 0
		padding 0
		list-style none
		font-size 20px
		@media (min-width: breakpoint)
			font-size inherit

		li
			position relative
			text-align left
			@media (min-width: breakpoint)
				display inline-block if navOrientation is horizontal
				display block if navOrientation is vertical

			a
				transition color .5s linear, background-color .5s linear
				text-decoration none
				display block
				padding 10px 20px
				color white
				@media (min-width: breakpoint)
					color #444

			// Links on hover/focus
			&:hover > a,
			&.focus > a
				outline none
				transition color .5s linear, background-color .5s linear

			// Links of list items that have submenus
			&.hasChildMenu > a
				padding-right 30px
				
				// Dropdown signifier arrows
				&:after
					@media (min-width: breakpoint)
						content ''
						display inline-block
						float right
						position absolute
						right 10px
						top 50%
						border-style solid
						border-color transparent
						border-width 4px
						margin-top (0 - @border-width / 2)
						border-left-color #444 if navOrientation is vertical
						border-top-color #444 if navOrientation is horizontal
						transition border-left-color .5s linear, transform .5s linear
						
			// Dropdown signifier arrows on hover/focus
			&.hasChildMenu:hover > a:after,
			&.hasChildMenu.focus > a:after
				@media (min-width: breakpoint)
					transition transform .5s linear
					transform translateY(5px) if navOrientation is horizontal
					transform translateX(5px) if navOrientation is vertical



			//////////////////////////////////////////////////////////
			// SECOND-LEVEL AND DEEPER MENUS	//////////////////////
			//////////////////////////////////////////////////////////
			// (all the dynamic ones)

			ul
				z-index 10
				margin-left 10%
				@media (min-width: breakpoint)
					transform translateY(-10px) translateX(0) if navOrientation is horizontal
					transform translateY(0) translateX(-10px) if navOrientation is vertical
					margin-left 0
					padding 10px 0
					background-color #F5F5F5
					box-shadow 1px 1px 1px rgba(0,0,0,.07)

				li
					@media (min-width: breakpoint)
						display block
						min-width 180px
						padding 0
						text-align left

					a
						font-size 85%

					// Dropdown signifier arrows
					if navOrientation == 'horizontal'
						&.hasChildMenu
							> a:after
								@media (min-width: breakpoint)
									border-left-color #444
									border-top-color transparent

							// Dropdown signifier arrows on hover/focus
							&:hover > a:after,
							&.focus > a:after
								@media (min-width: breakpoint)
									transform translateX(5px) translateY(0)



					//////////////////////////////////////////////////
					// THIRD-LEVEL AND DEEPER MENUS	//////////////////
					//////////////////////////////////////////////////
					// (all the side-flyout ones)

					ul
						@media (min-width: breakpoint)
							top 0
							transform translateY(0) translateX(-10px) if navOrientation is horizontal

						li
							// styles

							a
								// styles
									


							//////////////////////////////////////////
							// FOURTH-LEVEL AND DEEPER(?!) MENUS	//
							//////////////////////////////////////////
							// (second level of side-flyout menus)

							ul
								// styles

								li
									// styles

									a
										// styles



	//////////////////////////////////////////////////////////////////
	// MOBILE NAV	//////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////

	.mobileNav
		background #555

		&:after
			content "."
			display block
			clear both
			visibility hidden
			line-height 0
			height 0

		li
			float left

			&.menuToggle
				float right

				svg
					display block
					size 18px

	.burger
		padding 10px

		svg
			display block
			width 30px
			height 25px



	//////////////////////////////////////////////////////////////////
	// MOBILE SUBMENU TOGGLER BUTTONS	//////////////////////////////
	//////////////////////////////////////////////////////////////////

	.submenuTogglers
		border none
		background none
		position absolute
		top 0
		right 0
		size 33px

		i
			display block
			transform-origin center 20%
			border-style solid
			border-color transparent
			border-width 5px
			border-top-color white
			transition transform .25s linear
			margin (@height / 2 - @border-width) auto 0 auto
			size 0 // This needs to remain AFTER margin so that the @height reference bubbles

	li.hasChildMenu.open > .submenuTogglers i
		transform rotate(180deg)
		transition transform .25s linear



	//////////////////////////////////////////////////////////////////
	// MENU TRANSITIONS	//////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////

	li ul
		@media (min-width: breakpoint)
			// transform translateY(-10px)

			/*
			Hoverintent delay => Fade out and slide up => Position offscreen

			Time in seconds ->	0		.1      .2      .3      .4      .5
								|	|	|	|	|	|	|	|	|	|	|
			(hover intent) 		|---------------*
			opacity fade out	|				*---------------*
			translateY fade out |				*---------------*
			left out 			|									*
			*/
			transition opacity .2s linear .2s, transform .2s ease-out .2s, left 0s linear .45s

	li.focus > ul,
	li.focus > .menuPositioningWrapper > ul
		@media (min-width: breakpoint)
			/*
			Fade in and slide down immediately (no hoverintent delay)

			Time in seconds ->	0		.1      .2      .3      .4      .5
								|	|	|	|	|	|	|	|	|	|	|
			translate fade in	|---------------*
			opacity fade in     |---------------*
			*/
			transition transform .2s ease-out 0s, opacity .2s linear 0s

	li:hover > ul,
	li:hover > .menuPositioningWrapper > ul
		@media (min-width: breakpoint)
			/*
			Hoverintent delay => Position onscreen => Slide down and fade in

			Time in seconds ->	0		.1      .2      .3      .4      .5 		.6
								|	|	|	|	|	|	|	|	|	|	|	|	|
			(hover intent)		|---------------*
			left in				|				*
			translate fade in	|				*---------------*
			opacity fade in		|				*---------------*
			*/
			transition left 0s linear .2s, transform .2s ease-out .2s, opacity .2s linear .2s

	// If JS decides there is too little room in the viewport
	// for the menu to appear on the right, it will appear on
	// the left instead by applying the class "flip".
	
	li ul.flip
		@media (min-width: breakpoint)
			// transform translateY(-10px)

			/*
			Hoverintent delay => Fade out and slide up => Position offscreen

			Time in seconds ->	0		.1      .2      .3      .4      .5
								|	|	|	|	|	|	|	|	|	|	|
			(hover intent) 		|---------------*
			opacity fade out	|				*---------------*
			translateY fade out |				*---------------*
			right out 			|									*
			*/
			transition opacity .2s linear .2s, transform .2s ease-out .2s, right 0s linear .45s

	li.focus > ul.flip,
	li:hover > ul.flip,
	li.focus > .menuPositioningWrapper > ul.flip,
	li:hover > .menuPositioningWrapper > ul.flip
		@media (min-width: breakpoint)
			transition right 0s linear .2s, transform .2s ease-out .2s, opacity .2s linear .2s




	//////////////////////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////
	//
	// BASE VISIBILITY
	//
	//////////////////////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////


	// Antialiasing shift on transforms 	//////////////////////////
	
	-webkit-font-smoothing subpixel-antialiased

	// Menu visibility 	//////////////////////////////////////////////

	if mobileNavStyle is offscreen
		> ul
			display block
			position absolute
			right 100vw
			top 0
			width 200px
			height 100vh
			overflow auto
			@media (min-width: breakpoint)
				width auto
				height auto
				right auto
				top auto
				position static
				overflow visible

	// Hide submenus

	ul ul
		height 0
		overflow hidden
		@media (min-width: breakpoint)
			height auto
			overflow visible

	// Show submenus when parent .open class is applied via JS
	li.hasChildMenu.open > ul,
	li.hasChildMenu.open > .menuPositioningWrapper > ul
		height auto

	// Hide menus offscreen
	li ul
		@media (min-width: breakpoint)
			position absolute
			top auto if navOrientation is horizontal
			top 0 if navOrientation is vertical
			left -999em
			height auto !important
			overflow visible !important
			opacity .01

	// Menus slide effect finished state
	li.focus > ul,
	li:hover > ul,
	li.focus > .menuPositioningWrapper > ul,
	li:hover > .menuPositioningWrapper > ul
		@media (min-width: breakpoint)
			opacity 1
			transform translateY(0) translateX(0)
			left 100% if navOrientation is vertical
			left 0 if navOrientation is horizontal

	// Fly-out menus slide effect finished state
	li li.focus > ul,
	li li:hover > ul,
	li li.focus > .menuPositioningWrapper > ul,
	li li:hover > .menuPositioningWrapper > ul
		@media (min-width: breakpoint)
			left 100% if navOrientation is horizontal

	// Flipped menus (when side-flyouts can't fit in the viewport on the right side of the parent menu)
	li ul.flip
		@media (min-width: breakpoint)
			left auto
			right 99999em

	// Flipped menus visible states
	li.focus > ul.flip,
	li:hover > ul.flip,
	li.focus > .menuPositioningWrapper > ul.flip,
	li:hover > .menuPositioningWrapper > ul.flip
		@media (min-width: breakpoint)
			left auto !important
			right 100%


	// Mobile nav 	//////////////////////////////////////////////////

	.burger,
	.mobileNav
		display block
		@media (min-width: breakpoint)
			display none


	// Mobile elements 	//////////////////////////////////////////////

	.submenuTogglers
		@media (min-width: breakpoint)
			display none !important


// Entire nav visibility 	//////////////////////////////////////

if mobileNavStyle is offscreen

	body
		transition transform .15s linear
	
		&.gardenburgerMobileShow
			overflow hidden
			transform translateX(200px)
			transition transform .15s linear
			@media (min-width: breakpoint)
				transform translateX(0)
				overflow visible