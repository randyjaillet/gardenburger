//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Utility classes//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Show:// This is an animation that will animate an element's height from// 0 to its unknown inline value (set by JS to be equal to an// "auto" height). JS then removes the the inline value so the// height is actually "auto".@keyframes heightToInline	0%		height 0.animateHeightToInline	animation heightToInline .15s linear	overflow hidden// Hide:// This is a transition that will transition an element's height// from its unknown inline value (set by JS to be equal to an// "auto" height) to 0..height0	transition height .15s linear !important	height 0 !important	overflow hidden//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Options//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Below this value constitutes mobile mode. If you customize,// don't forget to set for JS as well at instantiation.breakpoint = 800px//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Settings used for calculations//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Vertical padding on the anchorsaVertPad = 10px// Vertical padding on the anchors in mobile modeaVertPadM = 20px// Leading (line-height) of the anchorsaLeading = 20px// Background of the nav in mobile mode. Other calculations are// based on this value (specifically whether it is light or dark)mobileNavBG = #EEE[data-gardenburger]	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	//	// Aesthetics	//	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Base - mostly shared by both mobile and desktop	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	box-sizing border-box			text-align center	font-size 20px	background #F5F5F5	*,	*:before,	*:after		box-sizing border-box	ul		margin 0		padding 0		list-style none		display flex		flex-direction column		li			flex-shrink 0			position relative			margin 0			padding 0			list-style none			text-align left			a,			.linkless-nav-item				display block				line-height aLeading				text-decoration none				&:focus					outline none			.linkless-nav-item				cursor default			ul				li									a,					.linkless-nav-item						font-size 85%	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// ONLY mobile	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	@media (max-width: breakpoint - 1)		// This constant acts as the basis for the progressive shading		// for opened deeper menus. Each A has a background derived		// from this, and each LI also gets a background behind that		// to shade the whole nav "section" when it is opened. These		// should be vivid, opaque (not at all transparent) colors		// because transparency will be added to them for the final		// values.		baseHighlightColor = light(mobileNavBG) ? black : white		ul,		.dropdown			li				margin-top 1px				transition background .2s linear				a,				.linkless-nav-item					padding aVertPadM 20px					color light(mobileNavBG) ? #444 : white					background rgba(baseHighlightColor, .04)				// This class is applied as soon as a submenu begins 				// opening and remains until it is closed. It flips the				// arrow and applies a background shade on the whole				// nav section.				&.opening					transition background .2s linear					background rgba(baseHighlightColor, .04)				// This class is applied by JS on LIs that contain ULs				// or .dropdowns				&.hasChildMenu					display flex					flex-wrap wrap						> a,					> .linkless-nav-item						flex 1 1 1px						margin-right 1px					// Mobile submenu togglers					.submenuTogglers						flex 0 0 (aVertPadM * 2 + aLeading)						appearance none						padding 0						border none						background rgba(baseHighlightColor, .08)							&:focus							outline none						i							display inline-block							transform-origin center 20%							border-style solid							border-color transparent							border-width 6px							border-top-color light(mobileNavBG) ? #444 : white							transition transform .25s linear							margin @border-width auto 0 auto							size 0					&.opening > .submenuTogglers i						transform rotate(180deg)						transition transform .25s linear					> ul,					> .dropdown						flex 1 1 100%				ul,				.dropdown					li						a,						.linkless-nav-item							padding-left 30px						ul,						.dropdown							li								a,								.linkless-nav-item									padding-left 40px								ul,								.dropdown									li										a,										.linkless-nav-item											padding-left 50px										ul,										.dropdown											li												a,												.linkless-nav-item													padding-left 60px		// Top-level UL only		> ul			background mobileNavBG			> li:first-child				margin-top 0		//////////////////////////////////////////////////////////////////		//////////////////////////////////////////////////////////////////		//		// Mobile nav toggle button		//		//////////////////////////////////////////////////////////////////		//////////////////////////////////////////////////////////////////		.burger			text-align left						barHeight = 4px			barGutter = 10px			a				display inline-block				vertical-align top				padding aVertPad				width 56px								&:focus					outline none				i					display block					height barHeight					background #333					transition transform .3s linear					+ i						margin-top barGutter										&:nth-child(2)						transition opacity .15s linear .15s			&.ex				a					i						transition all .3s linear						&:first-child							transform translateY((barHeight + barGutter)) rotate(135deg)						&:nth-child(2)							transition opacity .15s linear							opacity 0						&:last-child							transform translateY(-(barHeight + barGutter)) rotate(-135deg)	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Desktop	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	@media (min-width: breakpoint)		font-size inherit		//////////////////////////////////////////////////////////////////		// ALL MENUS		//////////////////////////////////////////////////////////////////		// (including the top-level, always-visible one)		ul			li				a,				.linkless-nav-item					transition color .5s linear, background-color .5s linear					padding aVertPad 20px					background none					color #444				// Links on hover/focus				&:hover > a,				&.focus > a,				&:hover > .linkless-nav-item,				&.focus > .linkless-nav-item					outline none					background-color rgba(0,0,0,.03)					transition color .5s linear, background-color .5s linear				// List items that have submenus				&.hasChildMenu:not(.no-indicator)					> a,					> .linkless-nav-item						padding-right 30px						// Dropdown signifier arrows						&:after							content ''							display inline-block							position absolute							right 10px							top 50%							border-style solid							border-color transparent							border-width 4px							margin-top (0 - @border-width / 2)							border-top-color #444							transition border-left-color .5s linear, transform .5s linear					// Dropdown signifier arrows on hover/focus					&:hover > a:after,					&.focus > a:after,					&:hover > .linkless-nav-item:after,					&.focus > .linkless-nav-item:after						transition transform .5s linear						transform translateY(5px)				//////////////////////////////////////////////////////////				// SECOND-LEVEL AND DEEPER MENUS				//////////////////////////////////////////////////////////				// (all the dynamic ones)				ul					padding 10px 0				ul,				.dropdown					width 200px					z-index 10					background-color #F5F5F5						li						min-width 180px						padding 0						text-align left							// Flyout signifier arrows						&.hasChildMenu:not(.no-indicator)							> a:after,							> .linkless-nav-item:after								border-left-color #444								border-top-color transparent								// Flyout signifier arrows on hover/focus							&:hover > a:after,							&.focus > a:after,							&:hover > .linkless-nav-item:after,							&.focus > .linkless-nav-item:after								transform translateX(5px) translateY(0)									//////////////////////////////////////////////////						// THIRD-LEVEL AND DEEPER MENUS						//////////////////////////////////////////////////						// (all the side-flyout ones)							ul,						.dropdown							top 0							li								// styles								a,								.linkless-nav-item									// styles								//////////////////////////////////////////								// FOURTH-LEVEL AND DEEPER(?!) MENUS								//////////////////////////////////////////								// (second level of side-flyout menus)								ul,								.dropdown									// styles									li										// styles										a,										.linkless-nav-item											// styles		//////////////////////////////////////////////////////////////////		// TOP UL ONLY		//////////////////////////////////////////////////////////////////		> ul			flex-direction row			flex-wrap wrap			justify-content center		//////////////////////////////////////////////////////////////////		// MENU TRANSITIONS		//////////////////////////////////////////////////////////////////		li:not(.not-hoverable) ul,		li:not(.not-hoverable) .dropdown			/*			Hoverintent delay => Fade out => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			(hover intent) 		|---------------*			opacity fade out	|				*---------------*			left out 			|									*			*/			transition opacity .2s linear .2s, left 0s linear .45s		li.not-hoverable > ul,		li.not-hoverable > .dropdown			/*			Fade out => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			opacity fade out	|---------------*			left out 			|					*			*/			transition opacity .2s linear, left 0s linear .25s		li.focus > ul,		li.focus > .dropdown,		li.locked-active > ul,		li.locked-active > .dropdown			/*			Fade in immediately (no hoverintent delay)			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			opacity fade in     |-----------*			*/			transition opacity .15s linear 0s		li:hover:not(.not-hoverable) > ul,		li:hover:not(.not-hoverable) > .dropdown			/*			Hoverintent delay => Position onscreen => Fade in				Time in seconds ->	0		.1      .2      .3      .4      .5 		.6								|	|	|	|	|	|	|	|	|	|	|	|	|			(hover intent)		|---------------*			left in				|				*			opacity fade in		|				*-----------*			*/			transition left 0s linear .2s, opacity .15s linear .2s			// If JS decides there is too little room in the viewport		// for the menu to appear on the right, it will appear on		// the left instead by applying the class "flip".		li:not(.not-hoverable) ul.flip,		li:not(.not-hoverable) .dropdown.flip			/*			Hoverintent delay => Fade out => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			(hover intent) 		|---------------*			opacity fade out	|				*---------------*			right out 			|									*			*/			transition right 0s linear .45s, opacity .2s linear .2s		li.focus:not(.not-hoverable) > ul.flip,		li:hover:not(.not-hoverable) > ul.flip,		li.focus:not(.not-hoverable) > .dropdown.flip,		li:hover:not(.not-hoverable) > .dropdown.flip			/*			Hoverintent delay => Position onscreen => Fade in				Time in seconds ->	0		.1      .2      .3      .4      .5 		.6								|	|	|	|	|	|	|	|	|	|	|	|	|			(hover intent)		|---------------*			right in			|				*			opacity fade in		|				*-----------*			*/			transition right 0s linear .2s, opacity .15s linear .2s	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	//	// Base	//	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Minimize the antialiasing shift on transforms	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	-webkit-font-smoothing subpixel-antialiased	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Visibility	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	// Hide menus offscreen	//////////////////////////////////////////////////////////////////	li ul,	li .dropdown		@media (min-width: breakpoint)			position absolute			left -999em			top auto			width 100%			height auto !important			overflow visible !important			opacity .01	@media (max-width: breakpoint - 1)		li.closed > ul,		li.closed > .dropdown,		&.mobileHide > ul			position absolute			left -999em			top auto			height auto			overflow visible			width 100%	//////////////////////////////////////////////////////////////////	// States	//////////////////////////////////////////////////////////////////	// Menus slide effect finished state	li.focus:not(.not-hoverable) > ul,	li:hover:not(.not-hoverable) > ul,	li.focus:not(.not-hoverable) > .dropdown,	li:hover:not(.not-hoverable) > .dropdown,	li.locked-active > ul,	li.locked-active > .dropdown		@media (min-width: breakpoint)			opacity 1			left 0	// Fly-out menus slide effect finished state	li li.focus:not(.not-hoverable) > ul,	li li:hover:not(.not-hoverable) > ul,	li li.focus:not(.not-hoverable) > .dropdown,	li li:hover:not(.not-hoverable) > .dropdown,	li li.locked-active > ul,	li li.locked-active > .dropdown		@media (min-width: breakpoint)			left 100%	// Flipped menus (when side-flyouts can't fit in the viewport on the right side of the parent menu)	li ul.flip,	li .dropdown.flip		@media (min-width: breakpoint)			left auto			right 99999em	// Flipped menus visible states	li.focus:not(.not-hoverable) > ul.flip,	li:hover:not(.not-hoverable) > ul.flip,	li.focus:not(.not-hoverable) > .dropdown.flip,	li:hover:not(.not-hoverable) > .dropdown.flip,	li.locked-active > ul.flip,	li.locked-active > .dropdown.flip		@media (min-width: breakpoint)			left auto !important			right 100%	//////////////////////////////////////////////////////////////////	// Mobile elements	//////////////////////////////////////////////////////////////////	.submenuTogglers		@media (min-width: breakpoint)			display none !important	.burger		display block		@media (min-width: breakpoint)			display none	li.hide-link-in-mobile > a,	li.hide-link-in-mobile > .linkless-nav-item		@media (max-width: breakpoint - 1)			display none