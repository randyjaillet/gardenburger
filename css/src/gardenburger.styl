//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Utility classes//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////@keyframes heightToInline	0%		height 0.animateHeightToInline	animation heightToInline .15s linear	overflow hidden.height0	transition height .15s linear !important	height 0 !important	overflow hidden//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Options//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Below this value constitutes mobile mode. If you customize,// don't forget to set for JS as well at instantiation.breakpoint = 800px//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Settings used for calculations//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Vertical padding on the anchorsaVertPad = 10px// Vertical padding on the anchors in mobile modeaVertPadM = 20px// Leading (line-height) of the anchorsaLeading = 20px// Background of the nav in mobile mode. Other calculations are// based on this value (specifically whether it is light or dark)mobileNavBG = #EEE[data-gardenburger]	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	//	// Aesthetics	//	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Base - mostly shared by both mobile and desktop	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	box-sizing border-box			text-align center	font-size 20px	background #F5F5F5	*,	*:before,	*:after		box-sizing border-box	ul		margin 0		padding 0		list-style none		display flex		flex-direction column		li			flex-shrink 0			position relative			margin 0			padding 0			list-style none			text-align left			a				display block				line-height aLeading				text-decoration none				&:focus					outline none			ul				li									a						font-size 85%	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// ONLY mobile	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	@media (max-width: breakpoint - 1)		// This var acts as the basis for the progressive shading		// for opened deeper menus. Each A has a background derived		// from this, and each LI also gets a background behind that		// to shade the whole nav "section" when it is opened.		baseHighlightColor = light(mobileNavBG) ? black : white		ul			li				margin-top 1px				transition background .2s linear				a					padding aVertPadM 20px					color light(mobileNavBG) ? #444 : white					background rgba(baseHighlightColor, .04)				// This class is applied as soon as a submenu begins 				// opening and remains until it is closed. It flips the				// arrow and applies a background shade on the whole				// nav section.				&.opening					transition background .2s linear					background rgba(baseHighlightColor, .04)				// This class is applied by JS on LIs that contain ULs				&.hasChildMenu					display flex					flex-wrap wrap						> a						flex 1 1 1px						margin-right 1px					// Mobile submenu togglers					.submenuTogglers						flex 0 0 (aVertPadM * 2 + aLeading) // full height of sibling A						appearance none						padding 0						border none						background rgba(baseHighlightColor, .08)							&:focus							outline none						i							display block							transform-origin center 20%							border-style solid							border-color transparent							border-width 6px							border-top-color light(mobileNavBG) ? #444 : white							transition transform .25s linear							margin @border-width auto 0 auto							size 0					&.opening > .submenuTogglers i						transform rotate(180deg)						transition transform .25s linear					> ul						flex 1 1 100%				ul					li						a							padding-left 30px						ul							li								a									padding-left 40px								ul									li										a											padding-left 50px										ul											li												a													padding-left 60px		// Top-level UL only		> ul			background mobileNavBG			> li:first-child				margin-top 0		//////////////////////////////////////////////////////////////////		//////////////////////////////////////////////////////////////////		//		// Mobile nav toggle button		//		//////////////////////////////////////////////////////////////////		//////////////////////////////////////////////////////////////////		.burger			text-align left			a				display inline-block				vertical-align top				padding aVertPad				width 50px				i					display block					height 6px					background #333					transform-origin -2px center					transition all .15s linear					+ i						margin-top @height			&.ex				a					i						transition all .15s linear						&:first-child							transform rotate(45deg)						&:nth-child(2)							transition opacity .15s linear							opacity 0						&:last-child							transform rotate(-45deg)	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Desktop	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	@media (min-width: breakpoint)		font-size inherit		//////////////////////////////////////////////////////////////////		// ALL MENUS		//////////////////////////////////////////////////////////////////		// (including the top-level, always-visible one)		ul			li				a					transition color .5s linear, background-color .5s linear					padding aVertPad 20px					background none					color #444				// Links on hover/focus				&:hover > a,				&.focus > a					outline none					background-color rgba(0,0,0,.03)					transition color .5s linear, background-color .5s linear				// List items that have submenus				&.hasChildMenu					> a						padding-right 30px						// Dropdown signifier arrows						&:after							content ''							display inline-block							position absolute							right 10px							top 50%							border-style solid							border-color transparent							border-width 4px							margin-top (0 - @border-width / 2)							border-top-color #444							transition border-left-color .5s linear, transform .5s linear					// Dropdown signifier arrows on hover/focus					&:hover > a:after,					&.focus > a:after						transition transform .5s linear						transform translateY(5px)				//////////////////////////////////////////////////////////				// SECOND-LEVEL AND DEEPER MENUS				//////////////////////////////////////////////////////////				// (all the dynamic ones)				ul					width 200px					padding 10px 0					z-index 10					transform translateY(-10px) translateX(0)					background-color #F5F5F5						li						min-width 180px						padding 0						text-align left							// Flyout signifier arrows						&.hasChildMenu							> a:after								border-left-color #444								border-top-color transparent								// Flyout signifier arrows on hover/focus							&:hover > a:after,							&.focus > a:after								transform translateX(5px) translateY(0)									//////////////////////////////////////////////////						// THIRD-LEVEL AND DEEPER MENUS						//////////////////////////////////////////////////						// (all the side-flyout ones)							ul							top 0							transform translateY(0) translateX(-10px)							li								// styles								a									// styles								//////////////////////////////////////////								// FOURTH-LEVEL AND DEEPER(?!) MENUS								//////////////////////////////////////////								// (second level of side-flyout menus)								ul									// styles									li										// styles										a											// styles		//////////////////////////////////////////////////////////////////		// TOP UL ONLY		//////////////////////////////////////////////////////////////////		> ul			flex-direction row			flex-wrap wrap			justify-content center		//////////////////////////////////////////////////////////////////		// MENU TRANSITIONS		//////////////////////////////////////////////////////////////////		li ul			// transform translateY(-10px)			/*			Hoverintent delay => Fade out and slide up => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			(hover intent) 		|---------------*			opacity fade out	|				*---------------*			translateY fade out |				*---------------*			left out 			|									*			*/			transition opacity .2s linear .2s, transform .2s ease-out .2s, left 0s linear .45s		li.focus > ul,		li.focus > .menuPositioningWrapper > ul			/*			Fade in and slide down immediately (no hoverintent delay)			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			translate fade in	|---------------*			opacity fade in     |---------------*			*/			transition transform .2s ease-out 0s, opacity .2s linear 0s		li:hover > ul,		li:hover > .menuPositioningWrapper > ul			/*			Hoverintent delay => Position onscreen => Slide down and fade in				Time in seconds ->	0		.1      .2      .3      .4      .5 		.6								|	|	|	|	|	|	|	|	|	|	|	|	|			(hover intent)		|---------------*			left in				|				*			translate fade in	|				*---------------*			opacity fade in		|				*---------------*			*/			transition left 0s linear .2s, transform .2s ease-out .2s, opacity .2s linear .2s			// If JS decides there is too little room in the viewport		// for the menu to appear on the right, it will appear on		// the left instead by applying the class "flip".		li ul.flip			// transform translateY(-10px)			/*			Hoverintent delay => Fade out and slide up => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			(hover intent) 		|---------------*			opacity fade out	|				*---------------*			translateY fade out |				*---------------*			right out 			|									*			*/			transition opacity .2s linear .2s, transform .2s ease-out .2s, right 0s linear .45s		li.focus > ul.flip,		li:hover > ul.flip,		li.focus > .menuPositioningWrapper > ul.flip,		li:hover > .menuPositioningWrapper > ul.flip			transition right 0s linear .2s, transform .2s ease-out .2s, opacity .2s linear .2s	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	//	// Base	//	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Minimize the antialiasing shift on transforms	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	-webkit-font-smoothing subpixel-antialiased	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Visibility	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	// Hide menus offscreen	//////////////////////////////////////////////////////////////////	li ul				@media (min-width: breakpoint)			position absolute			left -999em			top auto			width 100%			height auto !important			overflow visible !important			opacity .01	@media (max-width: breakpoint - 1)		li.closed > ul,		&.mobileHide > ul			position absolute			left -999em			top auto			height auto			overflow visible			width 100%	//////////////////////////////////////////////////////////////////	// States	//////////////////////////////////////////////////////////////////	// Menus slide effect finished state	li.focus > ul,	li:hover > ul,	li.focus > .menuPositioningWrapper > ul,	li:hover > .menuPositioningWrapper > ul		@media (min-width: breakpoint)			opacity 1			transform translateY(0) translateX(0)			left 0	// Fly-out menus slide effect finished state	li li.focus > ul,	li li:hover > ul,	li li.focus > .menuPositioningWrapper > ul,	li li:hover > .menuPositioningWrapper > ul		@media (min-width: breakpoint)			left 100%	// Flipped menus (when side-flyouts can't fit in the viewport on the right side of the parent menu)	li ul.flip		@media (min-width: breakpoint)			left auto			right 99999em	// Flipped menus visible states	li.focus > ul.flip,	li:hover > ul.flip,	li.focus > .menuPositioningWrapper > ul.flip,	li:hover > .menuPositioningWrapper > ul.flip		@media (min-width: breakpoint)			left auto !important			right 100%	//////////////////////////////////////////////////////////////////	// Mobile elements	//////////////////////////////////////////////////////////////////	.submenuTogglers		@media (min-width: breakpoint)			display none !important	.burger		display block		@media (min-width: breakpoint)			display none