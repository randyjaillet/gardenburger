//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Options//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Below this value constitutes mobile mode. If you customize,// don't forget to set for JS as well at instantiation.breakpoint = 800pxnavOrientation = horizontalmobileNavStyle = offscreen // offscreen or inline//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// Settings used for calculations//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////offscreenMobileNavWidth = 250pxaVertPad = 10pxaVertPadM = 20pxaLeading = 20pxmobileNavBG = #EEEbody > header > nav	box-sizing border-box		*,	*:before,	*:after		box-sizing border-box	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// Aesthetics	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////			text-align center	background #F5F5F5	//////////////////////////////////////////////////////////////////	// MOBILE STYLING	//////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	ul		baseHighlightColor = light(mobileNavBG) ? black : white			li			margin-top 1px			@media (min-width: breakpoint)				margin-top 0						&.open				background rgba(baseHighlightColor,.1)				@media (min-width: breakpoint)					background none							a				background rgba(baseHighlightColor,.1)				@media (min-width: breakpoint)					background none					&:hover,				&:focus					outline none					background rgba(baseHighlightColor,.2)				// Mobile submenu togglers			&.hasChildMenu							.submenuTogglers					flex 0 0 (aVertPadM * 2 + aLeading)					appearance none					padding 0					border none					background rgba(baseHighlightColor,.1)					transition background-color .5s linear										&:hover,					&:focus						outline none						background rgba(baseHighlightColor,.2)						transition background-color .5s linear								i						display block						transform-origin center 20%						border-style solid						border-color transparent						border-width 6px						border-top-color light(mobileNavBG) ? #444 : white						transition transform .25s linear						margin @border-width auto 0 auto						size 0 // This needs to remain AFTER margin so that the @height reference bubbles							&.open > .submenuTogglers i					transform rotate(180deg)					transition transform .25s linear						> ul					flex 1 1 100%	> ul > li:first-child		margin-top 0	ul		li						a				padding-left 20px						li							a					padding-left 30px									li									a						padding-left 40px										li											a							padding-left 50px							li													a								padding-left 60px	//////////////////////////////////////////////////////////////////	// TOP UL ONLY	//////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	> ul		background mobileNavBG		box-shadow inset -2px 0 5px -5px if mobileNavStyle is offscreen		@media (min-width: breakpoint)			background none			box-shadow none	//////////////////////////////////////////////////////////////////	// ALL MENUS	//////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	// (including the top-level, always-visible one)	ul		margin 0		padding 0		list-style none		font-size 20px		@media (min-width: breakpoint)			font-size inherit		li			position relative			text-align left			@media (min-width: breakpoint)				display inline-block if navOrientation is horizontal				display block if navOrientation is vertical			a				transition color .5s linear, background-color .5s linear				text-decoration none				display block				padding aVertPadM 20px				line-height aLeading				color light(mobileNavBG) ? #444 : white				@media (min-width: breakpoint)					padding aVertPad 20px					color #444			// Links on hover/focus			&:hover > a,			&.focus > a				@media (min-width: breakpoint)					outline none					background-color rgba(0,0,0,.03)					transition color .5s linear, background-color .5s linear			// List items that have submenus			&.hasChildMenu				@media (max-width: breakpoint - 1)					display flex					flex-wrap wrap							> a					flex 1 1 1px					margin-right 1px					@media (min-width: breakpoint)						margin-right 0						padding-right 30px										// Dropdown signifier arrows					&:after						@media (min-width: breakpoint)							content ''							display inline-block							float right							position absolute							right 10px							top 50%							border-style solid							border-color transparent							border-width 4px							margin-top (0 - @border-width / 2)							border-left-color #444 if navOrientation is vertical							border-top-color #444 if navOrientation is horizontal							transition border-left-color .5s linear, transform .5s linear				// Dropdown signifier arrows on hover/focus				&:hover > a:after,				&.focus > a:after					@media (min-width: breakpoint)						transition transform .5s linear						transform translateY(5px) if navOrientation is horizontal						transform translateX(5px) if navOrientation is vertical			//////////////////////////////////////////////////////////			// SECOND-LEVEL AND DEEPER MENUS	//////////////////////			//////////////////////////////////////////////////////////			// (all the dynamic ones)			ul				z-index 10				@media (min-width: breakpoint)					transform translateY(-10px) translateX(0) if navOrientation is horizontal					transform translateY(0) translateX(-10px) if navOrientation is vertical					padding 10px 0					background-color #F5F5F5				li					@media (min-width: breakpoint)						display block						min-width 180px						padding 0						text-align left					a						font-size 85%					// Dropdown signifier arrows					if navOrientation == 'horizontal'						&.hasChildMenu							> a:after								@media (min-width: breakpoint)									border-left-color #444									border-top-color transparent							// Dropdown signifier arrows on hover/focus							&:hover > a:after,							&.focus > a:after								@media (min-width: breakpoint)									transform translateX(5px) translateY(0)					//////////////////////////////////////////////////					// THIRD-LEVEL AND DEEPER MENUS	//////////////////					//////////////////////////////////////////////////					// (all the side-flyout ones)					ul						@media (min-width: breakpoint)							top 0							transform translateY(0) translateX(-10px) if navOrientation is horizontal						li							// styles							a								// styles																//////////////////////////////////////////							// FOURTH-LEVEL AND DEEPER(?!) MENUS	//							//////////////////////////////////////////							// (second level of side-flyout menus)							ul								// styles								li									// styles									a										// styles	//////////////////////////////////////////////////////////////////	// MOBILE NAV	//////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	.burger		text-align left		a			display inline-block			vertical-align top			padding aVertPad			height aLeading + aVertPad * 2			width aLeading * 1.23 + aVertPad * 2			//background url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20width%3D%2291.667%22%20height%3D%2275%22%20viewBox%3D%2254.167%2062.5%2091.667%2075%22%20fill%3D%22%23333%22%3E%3Cpath%20d%3D%22M54.167%2077.083c0%201.15.933%202.083%202.083%202.083h87.5c1.15%200%202.084-.933%202.084-2.083v-12.5c0-1.15-.934-2.083-2.084-2.083h-87.5c-1.15%200-2.083.933-2.083%202.083v12.5zm0%2029.167c0%201.15.933%202.084%202.083%202.084h87.5c1.15%200%202.084-.934%202.084-2.084v-12.5c0-1.15-.934-2.083-2.084-2.083h-87.5c-1.15%200-2.083.933-2.083%202.083v12.5zm0%2029.166c0%201.15.933%202.084%202.083%202.084h87.5c1.15%200%202.084-.933%202.084-2.084v-12.5c0-1.15-.934-2.082-2.084-2.082h-87.5c-1.15%200-2.083.932-2.083%202.082v12.5z%22/%3E%3C/svg%3E") 50% 50% no-repeat			//background-size auto aLeading						i				display block				height 4px				background #333				transform-origin 1px center				transition all .15s linear								+ i					margin-top 4px	//////////////////////////////////////////////////////////////////	// MENU TRANSITIONS	//////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	li ul		@media (min-width: breakpoint)			// transform translateY(-10px)			/*			Hoverintent delay => Fade out and slide up => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			(hover intent) 		|---------------*			opacity fade out	|				*---------------*			translateY fade out |				*---------------*			left out 			|									*			*/			transition opacity .2s linear .2s, transform .2s ease-out .2s, left 0s linear .45s	li.focus > ul,	li.focus > .menuPositioningWrapper > ul		@media (min-width: breakpoint)			/*			Fade in and slide down immediately (no hoverintent delay)			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			translate fade in	|---------------*			opacity fade in     |---------------*			*/			transition transform .2s ease-out 0s, opacity .2s linear 0s	li:hover > ul,	li:hover > .menuPositioningWrapper > ul		@media (min-width: breakpoint)			/*			Hoverintent delay => Position onscreen => Slide down and fade in			Time in seconds ->	0		.1      .2      .3      .4      .5 		.6								|	|	|	|	|	|	|	|	|	|	|	|	|			(hover intent)		|---------------*			left in				|				*			translate fade in	|				*---------------*			opacity fade in		|				*---------------*			*/			transition left 0s linear .2s, transform .2s ease-out .2s, opacity .2s linear .2s	// If JS decides there is too little room in the viewport	// for the menu to appear on the right, it will appear on	// the left instead by applying the class "flip".		li ul.flip		@media (min-width: breakpoint)			// transform translateY(-10px)			/*			Hoverintent delay => Fade out and slide up => Position offscreen			Time in seconds ->	0		.1      .2      .3      .4      .5								|	|	|	|	|	|	|	|	|	|	|			(hover intent) 		|---------------*			opacity fade out	|				*---------------*			translateY fade out |				*---------------*			right out 			|									*			*/			transition opacity .2s linear .2s, transform .2s ease-out .2s, right 0s linear .45s	li.focus > ul.flip,	li:hover > ul.flip,	li.focus > .menuPositioningWrapper > ul.flip,	li:hover > .menuPositioningWrapper > ul.flip		@media (min-width: breakpoint)			transition right 0s linear .2s, transform .2s ease-out .2s, opacity .2s linear .2s	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	//	// BASE VISIBILITY	//	//////////////////////////////////////////////////////////////////	//////////////////////////////////////////////////////////////////	// Antialiasing shift on transforms 	//////////////////////////		-webkit-font-smoothing subpixel-antialiased	// Menu visibility 	//////////////////////////////////////////////		ul		display none		@media (min-width: breakpoint)			display block !important		> ul		if mobileNavStyle is offscreen			display block !important			position absolute			left offscreenMobileNavWidth - offscreenMobileNavWidth * 2			top 0			width offscreenMobileNavWidth			height 100vh			overflow auto			@media (min-width: breakpoint)				width auto				height auto				right auto				top auto !important				position static				overflow visible	// Hide menus offscreen	li ul		@media (min-width: breakpoint)			position absolute			top auto if navOrientation is horizontal			top 0 if navOrientation is vertical			left -999em			height auto !important			overflow visible !important			opacity .01	// Menus slide effect finished state	li.focus > ul,	li:hover > ul,	li.focus > .menuPositioningWrapper > ul,	li:hover > .menuPositioningWrapper > ul		@media (min-width: breakpoint)			opacity 1			transform translateY(0) translateX(0)			left 100% if navOrientation is vertical			left 0 if navOrientation is horizontal	// Fly-out menus slide effect finished state	li li.focus > ul,	li li:hover > ul,	li li.focus > .menuPositioningWrapper > ul,	li li:hover > .menuPositioningWrapper > ul		@media (min-width: breakpoint)			left 100% if navOrientation is horizontal	// Flipped menus (when side-flyouts can't fit in the viewport on the right side of the parent menu)	li ul.flip		@media (min-width: breakpoint)			left auto			right 99999em	// Flipped menus visible states	li.focus > ul.flip,	li:hover > ul.flip,	li.focus > .menuPositioningWrapper > ul.flip,	li:hover > .menuPositioningWrapper > ul.flip		@media (min-width: breakpoint)			left auto !important			right 100%	// Mobile elements 	//////////////////////////////////////////////	.submenuTogglers		@media (min-width: breakpoint)			display none !important// Mobile button 	//////////////////////////////////////////////.burger	display block	@media (min-width: breakpoint)		display none	.gardenburgerMobileShow .burger,.mobileShow .burger		a			i			transition all .15s linear				&:first-child				transform rotate(45deg)						&:nth-child(2)				transition opacity .15s linear				opacity 0						&:last-child				transform rotate(-45deg)			if mobileNavStyle is offscreen	html		body			transition transform .15s linear			&.gardenburgerMobileShow			overflow hidden			@media (min-width: breakpoint)				overflow visible			body				overflow visible !important				transform translateX(offscreenMobileNavWidth)				transition transform .15s linear				@media (min-width: breakpoint)					transform translateX(0)